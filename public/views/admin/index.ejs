<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Admin — PAG</title>
  <link rel="stylesheet" href="/views/style.css" />
  <style>
    .admin-page {
      max-width: 860px;
      margin: 0 auto;
      padding: 3rem 2rem 6rem;
    }

    .admin-header {
      display: flex;
      align-items: baseline;
      gap: 1.5rem;
      margin-bottom: 2.5rem;
      border-bottom: 1px solid var(--border);
      padding-bottom: 1.25rem;
    }

    .admin-header h1 {
      font-size: 1rem;
      font-weight: 700;
      letter-spacing: -0.01em;
    }

    .admin-header a {
      font-size: 0.72rem;
      color: var(--muted);
      text-decoration: none;
    }
    .admin-header a:hover { color: var(--text); }

    .tools-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(240px, 1fr));
      gap: 1px;
      background: var(--border);
      border: 1px solid var(--border);
    }

    .tool-card {
      background: var(--bg);
      padding: 1.75rem;
      text-decoration: none;
      color: var(--text);
      display: flex;
      flex-direction: column;
      gap: 0.75rem;
      transition: background 0.15s;
      position: relative;
    }

    .tool-card:hover:not(.disabled) { background: rgba(0,0,0,0.02); }

    .tool-card.disabled {
      cursor: default;
      pointer-events: none;
    }

    .tool-icon {
      font-size: 1.4rem;
      line-height: 1;
    }

    .tool-name {
      font-size: 0.88rem;
      font-weight: 700;
      letter-spacing: -0.01em;
    }

    .tool-desc {
      font-size: 0.72rem;
      color: var(--muted);
      line-height: 1.5;
    }

    .tool-status {
      position: absolute;
      top: 1rem;
      right: 1rem;
      font-size: 0.58rem;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      color: var(--muted);
      border: 1px solid var(--border);
      padding: 0.15rem 0.4rem;
    }

    .tool-status.live {
      color: #2e7d32;
      border-color: #2e7d32;
    }

    .tool-arrow {
      margin-top: auto;
      font-size: 0.7rem;
      color: var(--muted);
    }
    .tool-card:hover:not(.disabled) .tool-arrow { color: var(--text); }
  </style>
</head>
<body>

  <%- include('../partials/navbar') %>

  <div class="admin-page">

    <div class="admin-header">
      <h1>admin</h1>
      <a href="/">← site</a>
    </div>

    <div class="tools-grid">

      <a href="/admin/products" class="tool-card">
        <span class="tool-status live">live</span>
        <div class="tool-icon">&#9634;</div>
        <div class="tool-name">products</div>
        <div class="tool-desc">add, edit, delete products and manage images, specs, I/O</div>
        <div class="tool-arrow">→</div>
      </a>

      <a href="/admin/events" class="tool-card disabled">
        <span class="tool-status">soon</span>
        <div class="tool-icon">&#9711;</div>
        <div class="tool-name">events</div>
        <div class="tool-desc">manage upcoming events shown on the home page</div>
        <div class="tool-arrow">→</div>
      </a>

      <a href="/admin/partners" class="tool-card disabled">
        <span class="tool-status">soon</span>
        <div class="tool-icon">&#9632;</div>
        <div class="tool-name">partners</div>
        <div class="tool-desc">manage partner logos in the partner bar</div>
        <div class="tool-arrow">→</div>
      </a>

      <a href="/admin/settings" class="tool-card disabled">
        <span class="tool-status">soon</span>
        <div class="tool-icon">&#9651;</div>
        <div class="tool-name">site settings</div>
        <div class="tool-desc">title, social links, contact info, global config</div>
        <div class="tool-arrow">→</div>
      </a>

    </div>

  </div>

</body>
</html>
