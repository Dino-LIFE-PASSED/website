<!DOCTYPE html>
<html lang="en">
<head>
  <link rel="icon" type="image/png" href="/images/pag_logo.png" />
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Dealer Login — PAG</title>
  <link rel="stylesheet" href="/views/style.css" />
  <style>
    body {
      display: flex;
      align-items: center;
      justify-content: center;
      min-height: 100vh;
      background: var(--bg);
    }

    .login-box {
      width: 100%;
      max-width: 360px;
      border: 1px solid var(--border);
      padding: 2.5rem;
    }

    .login-brand {
      font-size: 0.7rem;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      color: var(--muted);
      margin-bottom: 0.5rem;
    }

    .login-title {
      font-size: 1.2rem;
      font-weight: 700;
      letter-spacing: -0.03em;
      margin-bottom: 2rem;
    }

    .form-group {
      margin-bottom: 1rem;
    }

    .form-label {
      display: block;
      font-size: 0.62rem;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      color: var(--muted);
      margin-bottom: 0.4rem;
    }

    .form-input {
      width: 100%;
      font-family: var(--font);
      font-size: 0.88rem;
      color: var(--text);
      background: transparent;
      border: 1px solid var(--border);
      padding: 0.6rem 0.75rem;
      outline: none;
      transition: border-color 0.15s;
      box-sizing: border-box;
    }
    .form-input:focus { border-color: var(--text); }

    .btn-login {
      width: 100%;
      margin-top: 1.5rem;
      font-family: var(--font);
      font-size: 0.78rem;
      font-weight: 600;
      padding: 0.7rem;
      cursor: pointer;
      border: 1px solid var(--text);
      background: var(--text);
      color: var(--bg);
      letter-spacing: 0.04em;
      transition: opacity 0.15s;
    }
    .btn-login:hover { opacity: 0.85; }

    .error-msg {
      font-size: 0.72rem;
      color: var(--accent);
      margin-top: 1rem;
      padding: 0.5rem 0.75rem;
      border: 1px solid var(--accent);
    }

    .login-footer {
      margin-top: 2rem;
      font-size: 0.65rem;
      color: var(--muted);
      text-align: center;
    }
    .login-footer a { color: var(--muted); text-decoration: none; }
    .login-footer a:hover { color: var(--text); }
  </style>
</head>
<body>

  <div class="login-box">
    <p class="login-brand">PAG</p>
    <h1 class="login-title">dealer portal</h1>

    <form method="POST" action="/dealer/login">
      <div class="form-group">
        <label class="form-label" for="code">dealer code</label>
        <input class="form-input" type="text" id="code" name="code"
          placeholder="e.g. PAG-001" autocomplete="username" required />
      </div>
      <div class="form-group">
        <label class="form-label" for="password">password</label>
        <input class="form-input" type="password" id="password" name="password"
          autocomplete="current-password" required />
      </div>
      <button class="btn-login" type="submit">sign in</button>
      <% if (error) { %>
      <div class="error-msg"><%= error %></div>
      <% } %>
    </form>

    <p class="login-footer"><a href="/">← back to site</a></p>
  </div>

</body>
</html>
