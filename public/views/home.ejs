<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>PAG — Pro Audio Gadgets</title>
  <link rel="stylesheet" href="/views/style.css" />
</head>
<body>

  <%- include('partials/navbar') %>
  <%- include('partials/partners') %>
  <%- include('partials/wave') %>

  <main class="hero">

    <!-- Events -->
    <div class="section-events">
      <p class="section-tag">upcoming events</p>
      <h2 class="section-title">what's on</h2>
      <div class="events-grid">

        <div class="event-card">
          <div class="event-info">
            <span class="event-date">12 Jun 2026</span>
            <h3 class="event-name">PAG Demo Day Bangkok</h3>
            <p class="event-location">Central World &middot; Free entry</p>
          </div>
        </div>

        <div class="event-card">
          <div class="event-info">
            <span class="event-date">20 Jul 2026</span>
            <h3 class="event-name">Pro Audio Workshop</h3>
            <p class="event-location">Online &middot; Limited seats</p>
          </div>
        </div>

        <div class="event-card">
          <div class="event-info">
            <span class="event-date">05 Aug 2026</span>
            <h3 class="event-name">Sound Design Masterclass</h3>
            <p class="event-location">PAG Studio, Chiang Mai</p>
          </div>
        </div>

      </div>
    </div>

    <!-- Products -->
    <div class="section-products">
      <p class="section-tag">new arrivals</p>
      <h2 class="section-title">what's new</h2>
      <div class="products-featured">

        <div class="product-main">
          <div class="product-img-placeholder"></div>
          <div class="product-info">
            <span class="product-badge">featured</span>
            <h3 class="product-name">PAG-X1 Monitor</h3>
            <p class="product-desc">Reference-grade studio monitor engineered for flat response and zero coloration.</p>
            <div class="product-footer">
              <span class="product-price">$299</span>
              <a href="#" class="btn-primary">view product</a>
            </div>
          </div>
        </div>

        <div class="products-side">

          <div class="product-side-card">
            <div class="product-side-img"></div>
            <div class="product-info">
              <h3 class="product-name">PAG-EQ2 Headphone Amp</h3>
              <div class="product-footer">
                <span class="product-price">$499</span>
                <a href="#" class="btn-ghost">view</a>
              </div>
            </div>
          </div>

          <div class="product-side-card">
            <div class="product-side-img"></div>
            <div class="product-info">
              <h3 class="product-name">PAG-C3 Condenser Mic</h3>
              <div class="product-footer">
                <span class="product-price">$199</span>
                <a href="#" class="btn-ghost">view</a>
              </div>
            </div>
          </div>

        </div>
      </div>
    </div>

  </main>

</body>
</html>
