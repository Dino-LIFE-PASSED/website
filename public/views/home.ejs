<!DOCTYPE html>
<html lang="en">
<head>
  <link rel="icon" type="image/png" href="/images/pag_logo.png" />
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>PAG — Pro Audio Gadgets</title>
  <link rel="stylesheet" href="/views/style.css" />
</head>
<body>

  <%- include('partials/navbar') %>
  <%- include('partials/partners') %>
  <%- include('partials/wave') %>

  <main class="hero">

    <!-- Events -->
    <div class="section-events">
      <p class="section-tag">upcoming events</p>
      <h2 class="section-title">what's on</h2>
      <div class="events-grid">

        <div class="event-card">
          <div class="event-info">
            <span class="event-date">12 Jun 2026</span>
            <h3 class="event-name">PAG Demo Day Bangkok</h3>
            <p class="event-location">Central World &middot; Free entry</p>
          </div>
        </div>

        <div class="event-card">
          <div class="event-info">
            <span class="event-date">20 Jul 2026</span>
            <h3 class="event-name">Pro Audio Workshop</h3>
            <p class="event-location">Online &middot; Limited seats</p>
          </div>
        </div>

        <div class="event-card">
          <div class="event-info">
            <span class="event-date">05 Aug 2026</span>
            <h3 class="event-name">Sound Design Masterclass</h3>
            <p class="event-location">PAG Studio, Chiang Mai</p>
          </div>
        </div>

      </div>
    </div>

    <!-- Products -->
    <% if (products.length) { %>
    <% const mainProduct = products.find(p => p.badge === 'featured') || products[0] %>
    <% const sideProducts = products.filter(p => p.slug !== mainProduct.slug).slice(0, 2) %>
    <div class="section-products">
      <p class="section-tag">new arrivals</p>
      <h2 class="section-title">what's new</h2>
      <div class="products-featured">

        <div class="product-main">
          <div class="product-img-placeholder" <% if (mainProduct.image) { %>style="background-image: url('<%= mainProduct.image %>');"<% } %>></div>
          <div class="product-info">
            <% if (mainProduct.badge) { %><span class="product-badge"><%= mainProduct.badge %></span><% } %>
            <h3 class="product-name"><%= mainProduct.name %></h3>
            <p class="product-desc"><%= mainProduct.description %></p>
            <div class="product-footer">
              <span class="product-price">$<%= mainProduct.price %></span>
              <a href="/products/<%= mainProduct.slug %>" class="btn-primary">view product</a>
            </div>
          </div>
        </div>

        <div class="products-side">
          <% sideProducts.forEach(function(p) { %>
          <div class="product-side-card">
            <div class="product-side-img" <% if (p.image) { %>style="background-image: url('<%= p.image %>'); background-size: cover; background-position: center;"<% } %>></div>
            <div class="product-info">
              <h3 class="product-name"><%= p.name %></h3>
              <div class="product-footer">
                <span class="product-price">$<%= p.price %></span>
                <a href="/products/<%= p.slug %>" class="btn-ghost">view</a>
              </div>
            </div>
          </div>
          <% }) %>
        </div>

      </div>
    </div>
    <% } %>

  </main>

</body>
</html>
