<div class="partners-section">
  <div class="partners-track-wrapper">
    <div class="partners-track" id="track"></div>
  </div>
</div>

<script>
  const partnerbar = document.querySelector('.partners-section')
  const track = document.getElementById('track')

  function fill() {
    const original = Array.from(track.children)
    while (track.scrollWidth < window.innerWidth * 2) {
      original.forEach(el => track.appendChild(el.cloneNode(true)))
    }
  }

  fetch('/api/logos')
    .then(res => res.json())
    .then(files => {
      files.forEach(({ file, url }) => {
        const img = document.createElement('img')
        img.className = 'partner-logo'
        img.src = `/svg/${file}`
        img.alt = file.replace(/\.(svg|png)$/, '')
        if (url) {
          const a = document.createElement('a')
          a.href = /^https?:\/\//i.test(url) ? url : `https://${url}`
          a.target = '_blank'
          a.rel = 'noopener noreferrer'
          a.appendChild(img)
          track.appendChild(a)
        } else {
          track.appendChild(img)
        }
      })
      fill()
      document.documentElement.style.setProperty('--partnerbar-height', partnerbar.offsetHeight + 'px')
    })

  window.addEventListener('resize', fill)
</script>
