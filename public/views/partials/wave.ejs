<div class="wave-container">
    <canvas id="wave"></canvas>
  </div>

  <script>
  ;(function () {
    const canvas = document.getElementById('wave')
    const ctx    = canvas.getContext('2d')

    const PIXEL     = 36
    const GAP       = 3
    const GLOW      = 70          // headroom for shadowBlur at top
    const VISIBLE   = 144         // visible wave height (4 × PIXEL)
    const CONTAINER = VISIBLE + GLOW
    const ROWS      = Math.floor(VISIBLE / PIXEL)
    const LERP      = 0.12
    const MS        = 1000 / 16

    let cols     = 0
    let heights  = []
    let offsets  = []
    let tick     = 0
    let lastTime = 0

    function resize() {
      cols = Math.ceil(window.innerWidth / PIXEL)
      canvas.width        = window.innerWidth
      canvas.height       = CONTAINER
      canvas.style.width  = ''
      canvas.style.height = CONTAINER + 'px'
      heights = Array(cols).fill(0)
      offsets = Array.from({ length: cols }, () => [
        Math.random() * Math.PI * 2,
        Math.random() * Math.PI * 2,
        Math.random() * Math.PI * 2,
      ])
    }
    resize()
    window.addEventListener('resize', resize)

    function glowColor(col) {
      const hue = (col / cols) * 360
      return `hsl(${hue}, 100%, 45%)`
    }

    function getTarget(col) {
      const n = col / cols
      const [o1, o2, o3] = offsets[col]

      // Each column has its own independent slow oscillation — breaks up clumping
      const env  = Math.sin(tick * 0.01 + o1 * 4 + n * Math.PI * 2)
      const gate = Math.max(0, env + 0.5)
      if (gate === 0) return 0

      const a = Math.sin(tick * 0.025 + o1)
      const b = Math.sin(tick * 0.045 + o2)
      const c = Math.sin(tick * 0.07  + o3)
      const e = (a * 0.7 + b * 0.5 + c * 0.35 + 1.55) / 3.1
      return Math.min(ROWS, e * ROWS * gate * 1.1)
    }

    function draw(now) {
      requestAnimationFrame(draw)
      if (now - lastTime < MS) return
      lastTime = now

      ctx.clearRect(0, 0, canvas.width, canvas.height)

      for (let c = 0; c < cols; c++) {
        heights[c] += (getTarget(c) - heights[c]) * LERP
      }

      ctx.shadowBlur = 70
      for (let c = 0; c < cols; c++) {
        const filled = Math.round(heights[c])
        const x      = c * PIXEL
        const glow   = glowColor(c)
        ctx.shadowColor = glow
        ctx.fillStyle   = glow
        for (let r = 0; r < filled; r++) {
          const y = GLOW + VISIBLE - (r + 1) * PIXEL
          ctx.fillRect(x + GAP, y + GAP, PIXEL - GAP * 2, PIXEL - GAP * 2)
        }
      }

      const isDark = document.documentElement.getAttribute('data-theme') === 'dark'
      ctx.shadowBlur  = 0
      ctx.shadowColor = 'transparent'
      ctx.fillStyle   = isDark ? '#000000' : '#ffffff'
      for (let c = 0; c < cols; c++) {
        const filled = Math.round(heights[c])
        const x      = c * PIXEL
        for (let r = 0; r < filled; r++) {
          const y = GLOW + VISIBLE - (r + 1) * PIXEL
          ctx.fillRect(x + GAP, y + GAP, PIXEL - GAP * 2, PIXEL - GAP * 2)
        }
      }

      ctx.lineWidth = 1
      for (let c = 0; c < cols; c++) {
        const filled = Math.round(heights[c])
        const x      = c * PIXEL
        ctx.strokeStyle = glowColor(c)
        for (let r = 0; r < filled; r++) {
          const y = GLOW + VISIBLE - (r + 1) * PIXEL
          ctx.strokeRect(x + GAP + 0.5, y + GAP + 0.5, PIXEL - GAP * 2 - 1, PIXEL - GAP * 2 - 1)
        }
      }

      tick++
    }

    requestAnimationFrame(draw)
  })()
  </script>
