<!DOCTYPE html>
<html lang="en">
<head>
  <link rel="icon" type="image/png" href="/images/pag_logo.png" />
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= product.name %> — PAG</title>
  <link rel="stylesheet" href="/views/style.css" />
</head>
<body>

  <%- include('partials/navbar') %>
  <%- include('partials/partners') %>

  <div class="pd-page">

    <!-- Row 1: Gallery -->
    <div class="pd-gallery">
      <div class="pd-thumbs">
        <div class="pd-thumbs-track" id="pd-thumbs-track">
          <% for (let _copy = 0; _copy < 4; _copy++) { %>
          <% product.images.forEach(function(img, i) { %>
          <div class="pd-thumb <%= i === 0 && _copy === 0 ? 'active' : '' %>" data-src="<%= img %>" data-index="<%= i %>">
            <img src="<%= img %>" alt="<%= product.name %> view <%= i + 1 %>" loading="<%= _copy === 0 ? 'eager' : 'lazy' %>" onerror="this.style.display='none'" />
          </div>
          <% }) %>
          <% } %>
        </div>
      </div>
      <div class="pd-main-img" id="pd-main-img" data-image-count="<%= product.images.length %>">
        <img src="<%= product.images[0] %>" alt="<%= product.name %>" id="pd-main-img-el" />
      </div>
    </div>

    <script>
    ;(function () {
      const strip    = document.querySelector('.pd-thumbs')
      const thumbTrack = document.getElementById('pd-thumbs-track')
      const mainImg  = document.getElementById('pd-main-img-el')
      const imageCount = parseInt(document.getElementById('pd-main-img').dataset.imageCount, 10)

      /* Click: update main image (works on all 4 copies) */
      thumbTrack.addEventListener('click', e => {
        const thumb = e.target.closest('.pd-thumb')
        if (!thumb || !thumb.dataset.src) return
        const idx = thumb.dataset.index
        thumbTrack.querySelectorAll('.pd-thumb').forEach(t =>
          t.classList.toggle('active', t.dataset.index === idx)
        )
        mainImg.src = thumb.dataset.src
        mainImg.style.display = 'block'
      })

      /* Pause on hover / touch */
      strip.addEventListener('mouseenter', () => thumbTrack.style.animationPlayState = 'paused')
      strip.addEventListener('mouseleave', () => thumbTrack.style.animationPlayState = 'running')
      strip.addEventListener('touchstart', () => thumbTrack.style.animationPlayState = 'paused', { passive: true })
      strip.addEventListener('touchend',   () => thumbTrack.style.animationPlayState = 'running', { passive: true })

      /* Set speed then start */
      function initScroll() {
        if (!imageCount) return
        const thumbEl = thumbTrack.querySelector('.pd-thumb')
        if (!thumbEl) return
        const thumbW = thumbEl.getBoundingClientRect().width
        if (!thumbW) return
        const origWidth = imageCount * (thumbW + 1)
        thumbTrack.style.setProperty('--pd-dur', `${(origWidth / 80).toFixed(1)}s`)
        thumbTrack.classList.add('scrolling')
      }

      window.addEventListener('load', initScroll)
      window.addEventListener('resize', () => { thumbTrack.classList.remove('scrolling'); initScroll() })
    })()
    </script>

    <!-- Row 2: IO Diagram -->
    <div class="pd-io">

      <div class="io-side io-inputs">
        <p class="io-label">inputs</p>
        <% product.inputs.forEach(function(io) { %>
        <div class="io-item">
          <span class="io-count">×<%= io.count %></span>
          <span class="io-name"><%= io.name %></span>
          <img src="/svg/<%= io.icon %>" class="io-icon" alt="<%= io.name %>" />
          <span class="io-line"></span>
          <span class="io-dot"></span>
        </div>
        <% }) %>
      </div>

      <div class="io-center"></div>

      <div class="io-side io-outputs">
        <p class="io-label">outputs</p>
        <% product.outputs.forEach(function(io) { %>
        <div class="io-item">
          <span class="io-dot"></span>
          <span class="io-line"></span>
          <img src="/svg/<%= io.icon %>" class="io-icon" alt="<%= io.name %>" />
          <span class="io-name"><%= io.name %></span>
          <span class="io-count">×<%= io.count %></span>
        </div>
        <% }) %>
      </div>

    </div>

    <!-- Row 3: Info + Specs -->
    <div class="pd-body">

      <div class="pd-info">
        <% if (product.badge) { %><span class="pd-badge"><%= product.badge %></span><% } %>
        <h1 class="pd-name"><%= product.name %></h1>
        <p class="pd-price">$<%= product.price %></p>
        <p class="pd-desc"><%= product.desc %></p>
        <div class="pd-actions">
          <a href="#" class="btn-primary">buy now</a>
          <a href="#" class="btn-ghost">contact us</a>
        </div>
      </div>

      <div class="pd-specs">
        <p class="pd-specs-label">specifications</p>
        <table class="specs-table">
          <% product.specs.forEach(function(s) { %>
          <tr><td><%= s.label %></td><td><%= s.value %></td></tr>
          <% }) %>
        </table>
      </div>

    </div>

  </div>

</body>
</html>
