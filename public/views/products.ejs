<!DOCTYPE html>
<html lang="en">
<head>
  <link rel="icon" type="image/png" href="/images/pag_logo.png" />
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Products — PAG</title>
  <link rel="stylesheet" href="/views/style.css" />
</head>
<body>

  <%- include('partials/navbar') %>
  <%- include('partials/partners') %>

  <% const featured = products.find(p => p.badge === 'featured') || products[0] %>

  <!-- ==================== BANNER ==================== -->
  <% if (featured) { %>
  <section class="product-banner">
    <div class="banner-img" <% if (featured.image) { %>style="background-image: url('<%= featured.image %>'); background-size: cover; background-position: center;"<% } %>></div>
    <div class="banner-overlay">
      <% if (featured.badge) { %><span class="banner-badge"><%= featured.badge %></span><% } %>
      <h2 class="banner-name"><%= featured.name %></h2>
      <div class="banner-footer">
        <span class="banner-price">$<%= featured.price %></span>
        <a href="/products/<%= featured.slug %>" class="btn-primary">view product</a>
      </div>
    </div>
  </section>
  <% } %>

  <!-- ==================== PRODUCT GRID ==================== -->
  <section class="product-list-section">
    <div class="list-header">
      <p class="section-tag">all products</p>
      <!-- <h2 class="section-title">what we make</h2> -->
    </div>

    <div class="product-grid">
      <% products.forEach(function(p) {
        const inStock = (parseInt(p.stock) || 0) > 0
      %>
      <a href="/products/<%= p.slug %>" class="product-card">
        <div class="card-img-wrap">
          <% if (p.image) { %>
          <img class="card-img" src="<%= p.image %>" alt="<%= p.name %>" loading="lazy" />
          <% } else { %>
          <div class="card-img-placeholder">&#9634;</div>
          <% } %>
        </div>
        <div class="card-body">
          <div class="card-top">
            <span class="card-name"><%= p.name %></span>
            <% if (p.badge) { %><span class="card-badge"><%= p.badge %></span><% } %>
          </div>
          <span class="stock-tag <%= inStock ? 'in-stock' : 'pre-order' %>"><%= inStock ? 'in stock' : 'pre order' %></span>
          <div class="card-footer">
            <span class="card-price">฿<%= Number(p.price).toLocaleString('th-TH') %></span>
            <span class="btn-ghost">view</span>
          </div>
        </div>
      </a>
      <% }) %>
    </div>
  </section>

</body>
</html>
