<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Products — PAG</title>
  <link rel="stylesheet" href="/views/style.css" />
</head>
<body>

  <%- include('partials/navbar') %>
  <%- include('partials/wave') %>

  <!-- ==================== BANNER ==================== -->
  <section class="product-banner">
    <div class="banner-img"></div>
    <div class="banner-overlay">
      <span class="banner-badge">featured</span>
      <h2 class="banner-name">PAG-X1 Monitor</h2>
      <div class="banner-footer">
        <span class="banner-price">$299</span>
        <a href="#" class="btn-primary">view product</a>
      </div>
    </div>
  </section>

  <!-- ==================== PRODUCT GRID ==================== -->
  <section class="product-list-section">
    <div class="list-header">
      <p class="section-tag">all products</p>
      <h2 class="section-title">what we make</h2>
    </div>

    <div class="product-grid">

      <div class="product-card">
        <div class="card-img"></div>
        <div class="card-info">
          <div class="card-top">
            <h3 class="card-name">PAG-X1 Monitor</h3>
            <span class="card-badge">featured</span>
          </div>
          <p class="card-desc">Reference-grade studio monitor engineered for flat response and zero coloration.</p>
          <div class="card-footer">
            <span class="card-price">$299</span>
            <a href="#" class="btn-ghost">view</a>
          </div>
        </div>
      </div>

      <div class="product-card">
        <div class="card-img"></div>
        <div class="card-info">
          <div class="card-top">
            <h3 class="card-name">PAG-EQ2 Headphone Amp</h3>
            <span class="card-badge">new</span>
          </div>
          <p class="card-desc">High-fidelity headphone amplifier with built-in parametric EQ.</p>
          <div class="card-footer">
            <span class="card-price">$499</span>
            <a href="#" class="btn-ghost">view</a>
          </div>
        </div>
      </div>

      <div class="product-card">
        <div class="card-img"></div>
        <div class="card-info">
          <div class="card-top">
            <h3 class="card-name">PAG-C3 Condenser Mic</h3>
            <span class="card-badge">new</span>
          </div>
          <p class="card-desc">Large-diaphragm condenser microphone with wide frequency response.</p>
          <div class="card-footer">
            <span class="card-price">$199</span>
            <a href="#" class="btn-ghost">view</a>
          </div>
        </div>
      </div>

      <div class="product-card">
        <div class="card-img"></div>
        <div class="card-info">
          <div class="card-top">
            <h3 class="card-name">PAG-D4 DI Box</h3>
          </div>
          <p class="card-desc">Active direct injection box for clean signal routing from instruments to mixing consoles.</p>
          <div class="card-footer">
            <span class="card-price">$149</span>
            <a href="#" class="btn-ghost">view</a>
          </div>
        </div>
      </div>

      <div class="product-card">
        <div class="card-img"></div>
        <div class="card-info">
          <div class="card-top">
            <h3 class="card-name">PAG-P5 Preamp</h3>
          </div>
          <p class="card-desc">Single-channel tube microphone preamplifier with transformer-balanced outputs.</p>
          <div class="card-footer">
            <span class="card-price">$799</span>
            <a href="#" class="btn-ghost">view</a>
          </div>
        </div>
      </div>

    </div>
  </section>

</body>
</html>
